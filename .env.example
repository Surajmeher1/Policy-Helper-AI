# ========================================
# Flask Configuration
# ========================================
FLASK_ENV=production
FLASK_APP=app.py
SECRET_KEY=generate_with_python3_-c_import_secrets;_print(secrets.token_hex(32))

# ========================================
# API Keys (REQUIRED)
# ========================================
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
HF_MODEL_NAME=facebook/bart-large-cnn

# ========================================
# Email Configuration (Optional)
# ========================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here

# ========================================
# Database Configuration
# ========================================
# Type: sqlite (default), mysql, or postgresql
DB_TYPE=sqlite

# For AWS RDS MySQL: db-instance.xxxxx.us-east-1.rds.amazonaws.com
# DB_HOST=your-rds-endpoint.amazonaws.com
# DB_USER=admin
# DB_PASSWORD=your_secure_password
# DB_NAME=policy_helper_ai
# DB_PORT=3306

# For AWS RDS PostgreSQL:
# DB_HOST=your-rds-endpoint.amazonaws.com
# DB_USER=postgres
# DB_PASSWORD=your_secure_password
# DB_NAME=policy_helper_ai
# DB_PORT=5432

# ========================================
# Optional: AWS Configuration
# ========================================
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=policy-helper-ai-files (for file uploads)
# AWS_CLOUDWATCH_LOGS=true
