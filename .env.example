# GROQ API Configuration
# Get your API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Flask Configuration
SECRET_KEY=your_secret_key_here

# Flask Environment (development or production)
FLASK_ENV=development

# Model Configuration (default: llama-3.3-70b-versatile)
MODEL_NAME=llama-3.3-70b-versatile

# Server Configuration
PORT=5000

# Hugging Face Model Configuration (OPTIONAL - Only needed if using local HF models)
# The application now uses Groq API for text simplification instead of local models
# HF_MODEL_NAME=facebook/bart-large-cnn
# HF_TOKEN=your_hugging_face_token_here

# Email Configuration (Gmail SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here

# Database Configuration (Optional - for AWS RDS)
# DB_TYPE=sqlite (default) | mysql | postgresql
# DB_HOST=your-rds-host.rds.amazonaws.com
# DB_USER=admin
# DB_PASSWORD=your_db_password
# DB_NAME=policy_helper_ai
# DB_PORT=3306

# For production deployment
# FLASK_ENV=production
# DEBUG=False
